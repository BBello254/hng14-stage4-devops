events {}

http {
    server {
        listen {{ nginx_port }};
    
        log_format custom '$time_iso8601 | $status | ${request_time}s | $upstream_addr | $request';
        access_log /var/log/nginx/access.log custom;
    
        proxy_connect_timeout {{ proxy_timeout }}s;
        proxy_read_timeout {{ proxy_timeout }}s;
        proxy_send_timeout {{ proxy_timeout }}s;

        location / {
            set $upstream app:{{ service_port }};
            proxy_pass http://$upstream;
            add_header X-Deployed-By "swiftdeploy";
            proxy_set_header X-Mode $upstream_http_x_mode;
        }

        error_page 502 503 504 @error_json;
    
        location @error_json {
            default_type application/json;
            return 502 '{"error": "Service unavailable", "code": "502", "service": "app", "contact": "ops@swiftdeploy.io"}';
        }
    }
}